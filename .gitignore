# ---------------------------------------------------
# DATA DIRECTORIES
# ---------------------------------------------------
# Ignore all raw downloads (zips, gzips, massive TIFFs, Shapefiles, txt)
data/raw/*

# Ignore all interim pipeline data (Parquet files)
data/interim/*

# Ignore all processed data (GeoTIFFs, Parquets, XMLs) 
# EXCEPT the trained XGBoost JSON models required for the Streamlit app
data/processed/*
!data/processed/*.json